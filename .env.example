# Copy to ".env" and fill in:
#   cp .env.example .env

# Google Gemini — primary Analyzer provider. https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# OpenRouter — powers DeepSeek / Qwen / Llama providers. https://openrouter.ai/keys
# Optional: if unset, the gateway runs on Gemini alone.
OPENROUTER_API_KEY=""

# Groq — fast DeepSeek solver (Solver mode primary). https://console.groq.com/keys
# Optional: if unset, Solver falls back to OpenRouter/Gemini.
GROQ_API_KEY=""
